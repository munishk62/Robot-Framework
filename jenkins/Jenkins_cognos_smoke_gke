pipeline {
    agent { label "robot-node-ztm-4" }
    parameters {
        string(
            name: 'TEST_FILES_PATH',
            defaultValue: 'tests/web/l2_suite/rws/reports/cognos_custom_reports_smoketest.robot',
            description: 'List of robot test files or directories to execute (space-separated for multiple paths)'
        )
        string(
            name: 'TEST_ENV',
            defaultValue: 'QA28_B0',
            description: 'The environment name to run the tests against'
        )
        string(
            name: 'COGNOS_INPUT_FILE_NAME',
            defaultValue: 'cognos_custom_reports.xlsx',
            description: 'The input file name for Cognos custom report smoke tests'
        )
        choice(
            name: 'COGNOS_VERSION',
            choices: ['11', '12'],
            description: 'Set the Cognos version. This is used in the artifacts naming only.'
        )
        string(
            name: 'PARALLEL_PROCESSES',
            defaultValue: '4',
            description: 'Number of parallel processes.'
        )
        string(
            name: 'INCLUDE_TAGS',
            defaultValue: '',
            description: 'Only run tests with these tags (comma-separated). Leave empty to run all tests.'
        )
        string(
            name: 'RESULTS_DIR_PREFIX',
            defaultValue: 'results',
            description: 'Prefix for the directory to store test results. Name will be suffixed with the TEST_ENV'
        )
        string(name: 'EXTRA_ROBOT_ARGS', defaultValue: '', description: 'Additional robot execution arguments e.g. --variable COGNOS_REPORT_LONG_LOADING_TIMEOUT:600s')
        booleanParam(
            name: 'DRY_RUN',
            defaultValue: false,
            description: 'Perform a dry run without executing the tests'
        )

        choice(
            name: 'LOG_LEVEL',
            choices: ['INFO', 'DEBUG', 'WARNING', 'ERROR', 'CRITICAL'],
            description: 'Set the logging level'
        )

    }
    environment {
        // Jenkins workspace variables
        WORKSPACE_DIR = "${WORKSPACE}"
        RESULTS_DIR_NAME= "${params.RESULTS_DIR_PREFIX}_${params.TEST_ENV}"
        RESULTS_DIR_FULL = "${WORKSPACE}/${RESULTS_DIR_NAME}"
        LOG_FILE = "${WORKSPACE}/logs/jenkins_test_run_${BUILD_NUMBER}_${BUILD_TIMESTAMP}.log"
        
        // Python/UV related
        UV_CACHE_DIR = "${WORKSPACE}/.uv-cache"
        PYTHONPATH = "${WORKSPACE}"
        
        // Robot Framework specific
        ROBOT_OPTIONS = "--outputdir ${RESULTS_DIR_FULL} --loglevel ${params.LOG_LEVEL} --pythonpath ${WORKSPACE}"        
        PATH = "${HOME}/.npm-global/bin:${HOME}/.local/bin:${PATH}"
    }
    stages {
        stage('Checkout & Validate') {
            steps {
                   echo pwd()
                   cleanWs()
                   checkout scm
                    script {
                        def gitRevision = sh(returnStdout: true, script: "git rev-parse HEAD").trim()
                        env.GIT_REVISION = gitRevision
                        echo "Git Revision: ${env.GIT_REVISION}"
                    }
            }
        }
        stage('Check Environment Setup') {
            steps{
                script{
                    echo pwd()
                    
                    sh '''
                        ls -l
                        python3 --version
                        pip3 --version
                        # Check if UV is installed, if not install it
                        if ! command -v uv &> /dev/null; then
                            echo "Installing UV package manager..."
                            curl -LsSf https://astral.sh/uv/install.sh | sh
                            export PATH="$HOME/.local/bin:$PATH"
                        fi
                        
                        # Verify UV installation
                        uv --version

                    '''                    
                    // Ensure PATH includes UV
                    env.PATH = "${env.HOME}/.local/bin:${env.PATH}"               

                }
            }
        }
        stage('Install Dependencies') {
            steps {
                sh '''
                    mkdir -p "$HOME/.npm-global"
                    npm config set prefix "$HOME/.npm-global"
                    npm -v
                    node -v

                    # Install tools to user scope (no sudo needed)
                    npm install -g appium kill-port

                    # Verify and install Appium driver(s)
                    which appium || true
                    appium -v
                    appium driver ls || true
                    appium driver install uiautomator2
                    echo "Setting up Python environment with UV..."
                    pwd
                    # Create virtual environment
                    uv sync
                    pwd
                    # Install SWS Bundle dependencies
                    echo "Installing SWS RF Bundle dependencies..."
                    . .venv/bin/activate 
                    cd SWS_RF_Bundle_uv_jenkins
                    uv run python3 install_bundle.py
                    cd ..                           
                    echo "Dependencies installed successfully!"
                '''
            }
        }
        stage('Setup Credentials') {
            steps {
                script {
                    withCredentials([string(credentialsId: 'wfm-encryption-key', variable: 'ENCRYPTION_KEY')]) {
                        sh """
                        python decrypt_creds.py --test-env ${params.TEST_ENV}
                        """
                    }
                    
                }
            }
        }
        stage('Execute Tests') {
            steps {
                script {
                    sh """
                        echo "Starting test execution..."
                        pwd
                        uv run python executor.py ${params.TEST_FILES_PATH} --test-env ${params.TEST_ENV} --results-dir ${RESULTS_DIR_NAME} --cognos-input-filename ${params.COGNOS_INPUT_FILE_NAME} --testlevelsplit --processes ${params.PARALLEL_PROCESSES} ${params.INCLUDE_TAGS ? '--include-tags ' + params.INCLUDE_TAGS : ''} ${params.DRY_RUN ? '--dry-run' : ''}   ${params.EXTRA_ROBOT_ARGS} 
                    """
                }
            }
        }
        stage('Compress and Upload Artifacts') {
            environment {
                GOOGLE_APPLICATION_CREDENTIALS = credentials("rfx-eng-tm-auqa-t")                
            }
            steps {
                script {
                    sh """
                    ls -l ${RESULTS_DIR_NAME}
                    ls -l ${RESULTS_DIR_NAME}/browser/
                    echo "Compressing Artifacts"
                    echo $PWD                    
                    tar -czf "$WORKSPACE/allresults.tar.gz" "${RESULTS_DIR_NAME}"
                    echo 'Generating xlsx report from tests...'
                    chmod +x dev_utils/generate_cognos_report.sh
                    dev_utils/generate_cognos_report.sh "${RESULTS_DIR_NAME}" "${params.TEST_ENV}" "${params.COGNOS_VERSION}"
                    ls -l ${RESULTS_DIR_NAME}/customer_reports/
                    tar -czf "$WORKSPACE/customer_reports_${params.TEST_ENV}_${params.COGNOS_VERSION}_${BUILD_NUMBER}.tar.gz" "${RESULTS_DIR_NAME}/customer_reports"
                    echo 'Authenticating with GCP using env.GCS'
                    gcloud auth activate-service-account --key-file=${GOOGLE_APPLICATION_CREDENTIALS}
                    gcloud config set project rfx-eng-tm-auqa-t
                    CURRENT_DATE=\$(date +"%d%m%Y")
                    echo "Current date: \${CURRENT_DATE}"
                    echo "copy target path : gs://sit-qa-validation/Cognos_Reports/WST/\${CURRENT_DATE}/downloads_report_test/"
                    gsutil cp "$WORKSPACE/customer_reports_${params.TEST_ENV}_${params.COGNOS_VERSION}_${BUILD_NUMBER}.tar.gz" "gs://sit-qa-validation/Cognos_Reports/WST/\${CURRENT_DATE}/smoke_report_test/"
                    """
                }
                
            }
        }
    }
    post {
        always {
            script{
                 addBadge(icon: 'icon-gear', text: "Env: ${params.TEST_ENV}, ${params.PARALLEL_PROCESSES} Processes" )
                 addBadge(icon: 'icon-gear', text: "Cognos Version: ${params.COGNOS_VERSION}")
            }         
            
            // // Publish Robot Framework HTML reports
            // publishHTML([
            //     allowMissing: false,
            //     alwaysLinkToLastBuild: true,
            //     keepAll: true,
            //     reportDir: "${RESULTS_DIR_FULL}",
            //     reportFiles: 'report.html, log.html, rerun_report.html, rerun_log.html',
            //     reportName: 'Robot Framework Test Report',
            //     reportTitles: 'Robot Framework Report'
            // ])
            
            script {
                // cleanup workspace
                cleanWs()
            }
			// step([$class: 'ClassicUploadStep', credentialsId: "gke-zrs-terraform",  bucket: "gs://${env.GCS_BUCKET}/$JOB_NAME/$BUILD_NUMBER/", pattern: env.GCS_REPORT_NAME_PATTERN])
            echo 'Test execution completed.'
        }
    }
}
