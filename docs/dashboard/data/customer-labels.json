  "metrics": {
    "successRate": {
      "label": "Success rate",
      "definition": "Success rate = (passed + skipped) ÷ total tests. Treats skipped as non-failing."
    },
    "passRate": {
      "label": "Pass rate",
      "definition": "Pass rate = passed ÷ (total − skipped). Skipped tests are excluded from the denominator."
    },
    "skipRate": {
      "label": "Skip rate",
      "definition": "Skip rate = skipped ÷ total tests."
